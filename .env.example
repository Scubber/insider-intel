# Paths (JSONL MVP storage; swap for Postgres later via DATABASE_URL)
RAW_ARTICLES_PATH=data/raw/articles.jsonl
PROCESSED_ARTICLES_PATH=data/processed/articles.jsonl

# Search / reader API
SEARCH_HOST=127.0.0.1
SEARCH_PORT=8000

# Browser origins allowed to call the API (comma-separated).
# Local static UI defaults; add your Cloudflare Pages origin when hosting.
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:3000,http://localhost:3000,null

# Drop weak articles on process; UI stream uses the same default (0.15)
PROCESS_MIN_SCORE=0.15

# --- Postgres sidecar (docker compose) --------------------------------------
# Data plane is undecided; Postgres is the compose default so it can be swapped
# later. Only shared/settings.py reads DATABASE_URL — keep it that way.
# Safe local-only defaults; compose falls back to these same values when unset.
# POSTGRES_USER=insider
# POSTGRES_PASSWORD=insider
# POSTGRES_DB=insider_intel
# POSTGRES_PORT=5432
# UI_PORT=5500
# In-container URL (host `db` is the compose service). From the WSL host use
# localhost:${POSTGRES_PORT} instead. docker-compose.yml already injects this;
# uncomment only to override.
# DATABASE_URL=postgresql://insider:insider@db:5432/insider_intel

# Feedly Cloud API — optional inspiration only (not required for MVP).
# Prefer Google Alerts + CourtListener + multi-domain RSS — see docs/sourcing.md.
# FEEDLY_ACCESS_TOKEN=
# FEEDLY_STREAM_IDS=enterprise/your-team/tag/insider-threats-x-top-stories,user/xxx/tag/itm-hunt
# FEEDLY_COUNT=50
# FEEDLY_MAX_PAGES=2

# CourtListener RECAP (optional token from Free Law Project; anonymous works with limits)
# COURTLISTENER_API_TOKEN=
# Override defaults with comma-separated queries, e.g. employment / overemployment-adjacent:
# COURTLISTENER_QUERIES="insider trading",moonlighting employee,"concurrent employment","conflict of interest" employee
# COURTLISTENER_PAGE_SIZE=20
# COURTLISTENER_MAX_PAGES=1
# Search types to pull: dockets,opinions or "all" (default dockets = RECAP only)
# COURTLISTENER_TYPES=dockets
# Opinion-specific queries (empty = COURTLISTENER_QUERIES / built-in defaults)
# COURTLISTENER_OPINION_QUERIES=
# Fetch full opinion bodies for ITM scoring (1 extra GET per new opinion; token recommended)
# COURTLISTENER_FETCH_OPINION_TEXT=true
# COURTLISTENER_OPINION_TEXT_MAX_CHARS=20000
# Incremental re-runs: filed_after watermark overlap window, in days
# COURTLISTENER_LOOKBACK_DAYS=3

# Google Alerts (or similar) RSS URLs — primary free discovery for HR/legal/business risk.
# Create alerts for: overemployment, moonlighting employee, "concurrent employment", etc.
# Then paste the RSS URLs here (comma-separated). See docs/sourcing.md.
# WEB_KEYWORD_FEED_URLS=https://www.google.com/alerts/feeds/...

# DataTheftNews — no public RSS; pulls published posts via their public Supabase API.
# Anon key is discovered from the SPA when unset (same key their frontend ships).
# DATATHEFTNEWS_SUPABASE_URL=https://efjoefkaplfsgqwrbseg.supabase.co
# DATATHEFTNEWS_ANON_KEY=
# DATATHEFTNEWS_LIMIT=200

# One-way corporate export API (GET /export/articles). Never put corp Graph/SIEM
# credentials here — corporate tools pull OUT with this bearer token.
# EXPORT_API_TOKEN=replace-with-long-random-secret

# POST /extract/ttps can spend LLM credits — sliding-window caps (<=0 disables)
# EXTRACT_RATE_PER_IP_HOUR=20
# EXTRACT_RATE_GLOBAL_DAY=200

# xAI / Grok — optional LLM fill for Workbench Extract TTPs (POST /extract/ttps).
# Without a key, Extract still returns the curated IF038 seed pack.
# XAI_API_KEY=
# XAI_MODEL=grok-3-mini
